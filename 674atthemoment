-- Anti-AFK
local antiAfkConn
Tabs.Misc:AddToggle("antiAfk", {
    Title   = "Anti-AFK",
    Default = false
}):OnChanged(function(state)
    if state then
        antiAfkConn = task.spawn(function()
            while true do
                task.wait(55)
                local vp = player:FindFirstChild("PlayerGui")
                if vp then
                    -- Simulate a small movement to reset idle timer
                    local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
                    if hum then hum:Move(Vector3.new(0.01, 0, 0), false) end
                end
            end
        end)
    else
        if antiAfkConn then
            task.cancel(antiAfkConn)
            antiAfkConn = nil
        end
    end
end)

