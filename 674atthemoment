    Callback = function()
        local sel = Options.playerSelect and Options.playerSelect.Value
        if not sel then return end
        local target = Players:FindFirstChild(sel)
        if not target or not target.Character then
            Fluent:Notify({ Title = "Error", Content = "Player not found or no character", Duration = 4 })
