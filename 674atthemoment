-- ─── Fly ──────────────────────────────────────────────────────────────────────
Tabs.Movement:AddSection("Fly  [RightCtrl to toggle]")

Tabs.Movement:AddToggle("flyToggle", {
    Title   = "Fly",
    Default = false
}):OnChanged(function(state)
    flying = state
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    if state then
        bodyVel           = Instance.new("BodyVelocity")
        bodyVel.MaxForce  = Vector3.new(9e9, 9e9, 9e9)
        bodyVel.Velocity  = Vector3.zero
        bodyVel.Parent    = hrp

        bodyGyro           = Instance.new("BodyGyro")
        bodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
        bodyGyro.CFrame    = hrp.CFrame
        bodyGyro.Parent    = hrp

        task.spawn(function()
            while flying and hrp.Parent do
                local cam  = workspace.CurrentCamera
                local move = Vector3.zero
                if UserInputService:IsKeyDown(Enum.KeyCode.W) then move += cam.CFrame.LookVector  end
                if UserInputService:IsKeyDown(Enum.KeyCode.S) then move -= cam.CFrame.LookVector  end
                if UserInputService:IsKeyDown(Enum.KeyCode.A) then move -= cam.CFrame.RightVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.D) then move += cam.CFrame.RightVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.Space)       then move += Vector3.yAxis end
                if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then move -= Vector3.yAxis end

                local speed     = Options.flySpeed and Options.flySpeed.Value or flySpeed
                local targetVel = move.Magnitude > 0 and (move.Unit * speed) or Vector3.zero
                bodyVel.Velocity = bodyVel.Velocity:Lerp(targetVel, 0.2)
                bodyGyro.CFrame  = cam.CFrame
                RunService.RenderStepped:Wait()
            end
            pcall(function() bodyVel:Destroy(); bodyGyro:Destroy() end)
        end)
    else
        pcall(function() bodyVel:Destroy(); bodyGyro:Destroy() end)
    end
end)

Tabs.Movement:AddSlider("flySpeed", {
    Title    = "Fly Speed",
    Min      = 20,
    Max      = 500,
    Default  = 50,
    Rounding = 1
}):OnChanged(function(v) flySpeed = v end)

-- ─── Noclip ───────────────────────────────────────────────────────────────────
Tabs.Movement:AddSection("Noclip  [V to toggle]")

Tabs.Movement:AddToggle("noclipToggle", {
    Title   = "Noclip",
    Default = false
}):OnChanged(function(v) noclipping = v end)

-- Noclip loop — skips during ghost teleport which handles its own collision
RunService.Stepped:Connect(function()
    if noclipping and not isTeleporting and player.Character then
        for _, part in pairs(player.Character:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    end
end)

-- Keybinds: RightCtrl = fly | V = noclip
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.RightControl then
        Options.flyToggle:SetValue(not Options.flyToggle.Value)
    elseif input.KeyCode == Enum.KeyCode.V then
        Options.noclipToggle:SetValue(not Options.noclipToggle.Value)
    end
end)

