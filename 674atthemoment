-- ─── Instant Ghost Teleport (wall-proof) ─────────────────────────────────────
-- Anchors the HRP, warps CFrame directly, unanchors.
-- Never travels through geometry so walls/aura hitboxes can't block it.
local function ghostTeleport(targetCFrame, callback)
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end

    isTeleporting = true

    -- 1. Kill all collision
    local collideStates = {}
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            collideStates[part] = part.CanCollide
            part.CanCollide = false
        end
    end

    -- 2. Freeze humanoid so it doesn't fight the warp
    hum:ChangeState(Enum.HumanoidStateType.Physics)

    -- 3. Anchor → zero velocity → warp → unanchor (zero geometry travel)
    hrp.Anchored    = true
    hrp.Velocity    = Vector3.zero
    hrp.RotVelocity = Vector3.zero
    hrp.CFrame      = targetCFrame
    task.wait()          -- one frame for physics engine to settle
    hrp.Anchored    = false

    -- 4. Resume humanoid
    hum:ChangeState(Enum.HumanoidStateType.GettingUp)

    -- 5. Restore collision after a short buffer (respects global noclip)
    task.wait(0.1)
    if not noclipping then
        for part, state in pairs(collideStates) do
            if part and part.Parent then
                part.CanCollide = state
            end
        end
    end

    isTeleporting = false
    if callback then callback() end
end

-- ─── Morphs Setup ────────────────────────────────────────────────────────────
local morphsFolder = workspace:WaitForChild("Morphs", 10)
if not morphsFolder then
    Fluent:Notify({ Title = "Error", Content = "Morphs folder not found!", Duration = 6 })
    return
end

local morphList        = {}
local currentTourIndex = 0
local selectedMorph    = nil
local autoTourActive   = false
local autoTourDelay    = 3

local function refreshMorphs()
    morphList = {}
    for _, obj in ipairs(morphsFolder:GetDescendants()) do
        local primary = obj:IsA("BasePart") and obj
            or (obj:IsA("Model") and obj.PrimaryPart)
        if primary then
            table.insert(morphList, { Name = obj.Name, CFrame = primary.CFrame })
        end
    end
    local names = {}
    for _, m in ipairs(morphList) do table.insert(names, m.Name) end
    return names
end

local morphNames = refreshMorphs()

-- ─── TELEPORT TAB ─────────────────────────────────────────────────────────────
Tabs.Teleport:AddSection("Single Teleport")

local dropdown = Tabs.Teleport:AddDropdown("morphSelect", {
    Title   = "Select Morph",
    Values  = morphNames,
    Default = 1,
    Multi   = false
})

dropdown:OnChanged(function(value)
    for _, m in ipairs(morphList) do
        if m.Name == value then
            selectedMorph = m
            Fluent:Notify({ Title = "Selected", Content = "Ready: " .. m.Name, Duration = 2 })
            break
        end
    end
end)

Tabs.Teleport:AddSlider("tpHeight", {
    Title    = "Spawn Height Offset",
    Min      = 0,
    Max      = 20,
    Default  = 5,
    Rounding = 1
})

Tabs.Teleport:AddButton({
    Title = "Teleport to Selected",
    Callback = function()
        if not selectedMorph then
            Fluent:Notify({ Title = "Error", Content = "Select a morph first!", Duration = 4 })
            return
        end
        local heightOff = Options.tpHeight and Options.tpHeight.Value or 5
        local dest = selectedMorph.CFrame + Vector3.new(0, heightOff, 0)
        ghostTeleport(dest, function()
            Fluent:Notify({ Title = "Arrived", Content = selectedMorph.Name, Duration = 2 })
        end)
    end
})

-- ─── Manual Tour ─────────────────────────────────────────────────────────────
Tabs.Teleport:AddSection("Manual Tour")

local tourLabel = Tabs.Teleport:AddParagraph({ Title = "Tour Status", Content = "Not started" })

Tabs.Teleport:AddButton({
    Title = "⏭  Next Morph",
    Callback = function()
        if #morphList == 0 then
            Fluent:Notify({ Title = "Empty", Content = "No morphs found!", Duration = 4 })
            return
        end
        currentTourIndex = (currentTourIndex % #morphList) + 1
        local morph     = morphList[currentTourIndex]
        local heightOff = Options.tpHeight and Options.tpHeight.Value or 5
        ghostTeleport(morph.CFrame + Vector3.new(0, heightOff, 0))
        tourLabel:Set({ Content = morph.Name .. " (" .. currentTourIndex .. "/" .. #morphList .. ")" })
        Fluent:Notify({ Title = "Tour", Content = "→ " .. morph.Name, Duration = 2 })
    end
})

Tabs.Teleport:AddButton({
    Title = "⏮  Previous Morph",
    Callback = function()
        if #morphList == 0 then return end
        currentTourIndex = currentTourIndex - 1
        if currentTourIndex < 1 then currentTourIndex = #morphList end
        local morph     = morphList[currentTourIndex]
        local heightOff = Options.tpHeight and Options.tpHeight.Value or 5
        ghostTeleport(morph.CFrame + Vector3.new(0, heightOff, 0))
        tourLabel:Set({ Content = morph.Name .. " (" .. currentTourIndex .. "/" .. #morphList .. ")" })
        Fluent:Notify({ Title = "Tour", Content = "← " .. morph.Name, Duration = 2 })
    end
})

Tabs.Teleport:AddButton({
    Title = "↺  Reset Tour",
    Callback = function()
        currentTourIndex = 0
        tourLabel:Set({ Content = "Reset — click Next to begin" })
    end
})

-- ─── Auto Tour ────────────────────────────────────────────────────────────────
Tabs.Teleport:AddSection("Auto Tour")

Tabs.Teleport:AddSlider("autoTourDelay", {
    Title    = "Delay Between Morphs (s)",
    Min      = 1,
    Max      = 30,
    Default  = 3,
    Rounding = 1
}):OnChanged(function(v) autoTourDelay = v end)

Tabs.Teleport:AddToggle("autoTourToggle", {
    Title   = "Auto Tour",
    Default = false
}):OnChanged(function(state)
    autoTourActive = state
    if state then
        task.spawn(function()
            while autoTourActive do
                if #morphList == 0 then break end
                currentTourIndex = (currentTourIndex % #morphList) + 1
                local morph     = morphList[currentTourIndex]
                local heightOff = Options.tpHeight and Options.tpHeight.Value or 5
                ghostTeleport(morph.CFrame + Vector3.new(0, heightOff, 0))
                tourLabel:Set({ Content = "[AUTO] " .. morph.Name .. " (" .. currentTourIndex .. "/" .. #morphList .. ")" })
                task.wait(autoTourDelay)
            end
        end)
    end
end)

